{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/scope-guard/scope-guard-plan.schema.json",
  "title": "Scope Guard Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "taskId",
    "userGoal",
    "scope",
    "design",
    "pseudocode",
    "implementation",
    "docs"
  ],
  "properties": {
    "version": { "const": "1.0" },
    "taskId": { "type": "string" },
    "userGoal": { "type": "string" },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inScope", "outOfScope", "assumptions", "openQuestions"],
      "properties": {
        "inScope": { "type": "array", "items": { "type": "string" } },
        "outOfScope": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "openQuestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "extensionPoints", "rejectedAlternatives"],
      "properties": {
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentDesign" }
        },
        "extensionPoints": { "type": "array", "items": { "type": "string" } },
        "rejectedAlternatives": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pseudocode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft", "reviewFindings", "approved"],
      "properties": {
        "draft": { "type": "string" },
        "reviewFindings": { "type": "array", "items": { "type": "string" } },
        "approved": { "type": "boolean" }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changedFiles", "testsAddedOrUpdated", "knownRisks"],
      "properties": {
        "changedFiles": { "type": "array", "items": { "type": "string" } },
        "testsAddedOrUpdated": { "type": "array", "items": { "type": "string" } },
        "knownRisks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["designDocUpdated", "diagramsUpdated", "docChanges"],
      "properties": {
        "designDocUpdated": { "type": "boolean" },
        "diagramsUpdated": { "type": "boolean" },
        "docChanges": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "componentDesign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "responsibility", "dependencies", "extensionPoints"],
      "properties": {
        "name": { "type": "string" },
        "responsibility": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "extensionPoints": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
