{
    "name": "scope-guard",
    "version": "1.0.0",
    "description": "Scoped coding partner that enforces scope, single-purpose design, pseudocode review, and documentation deltas before and during implementation.",
    "type": "module",
    "private": true,
    "bin": {
        "scope-guard": "./bin/scope-guard.mjs"
    },
    "scripts": {
        "test": "node --test test/**/*.test.mjs",
        "validate": "node bin/scope-guard.mjs check --plan skills/scope-guard/examples/valid-plan.json",
        "summary": "node bin/scope-guard.mjs summary --plan skills/scope-guard/examples/valid-plan.json"
    },
    "engines": {
        "node": ">=20"
    }
}
