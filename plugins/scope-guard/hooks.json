{
    "SessionStart": [
        {
            "name": "scope-guard-init",
            "command": "node bin/scope-guard.mjs init",
            "timeoutSeconds": 10
        }
    ],
    "Stop": [
        {
            "name": "scope-guard-check",
            "command": "node bin/scope-guard.mjs check",
            "timeoutSeconds": 10
        }
    ]
}
