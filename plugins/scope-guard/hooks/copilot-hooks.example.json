{
    "hooks": {
        "sessionStart": [
            {
                "name": "scope-guard-init",
                "command": "node plugins/scope-guard/bin/scope-guard.mjs init",
                "timeoutSeconds": 10
            }
        ],
        "sessionEnd": [
            {
                "name": "scope-guard-check",
                "command": "node plugins/scope-guard/bin/scope-guard.mjs check",
                "timeoutSeconds": 10
            }
        ]
    }
}
