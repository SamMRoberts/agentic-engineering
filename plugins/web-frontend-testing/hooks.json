{
    "hooks": {
        "PreToolUse": [
            {
                "type": "command",
                "command": "node hooks/block-credentials.mjs",
                "timeout": 10
            },
            {
                "type": "command",
                "command": "node hooks/confirm-browser-evaluate.mjs",
                "timeout": 10
            }
        ],
        "PostToolUse": [
            {
                "type": "command",
                "command": "node hooks/validate-test-plan.mjs",
                "timeout": 15
            }
        ]
    }
}