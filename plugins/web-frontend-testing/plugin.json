{
    "agents": "agents",
    "skills": "skills",
    "entrypointAgent": "web-frontend-testing",
    "privateAgents": [
        "web-frontend-testing-requirements",
        "web-frontend-testing-plan",
        "web-frontend-testing-execution",
        "web-frontend-testing-cli-execution",
        "web-frontend-testing-results"
    ],
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "web-frontend-report-viewer": {
            "command": "npm",
            "args": [
                "--prefix",
                "./mcp-app",
                "run",
                "start:stdio"
            ]
        },
        "web-frontend-testing-workflow": {
            "command": "npm",
            "args": [
                "--prefix",
                "./mcp-workflow",
                "run",
                "start:stdio"
            ]
        }
    }
}