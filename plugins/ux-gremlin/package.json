{
  "name": "ux-gremlin",
  "version": "1.0.0",
  "description": "Generate hostile-but-realistic UX resilience scenarios from normal web flows.",
  "type": "module",
  "private": true,
  "bin": {
    "ux-gremlin": "./skills/ux-gremlin/scripts/ux-gremlin.mjs"
  },
  "scripts": {
