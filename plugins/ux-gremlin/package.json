{
  "name": "ux-gremlin",
  "version": "3.0.0",
  "description": "Generate hostile-but-realistic UX resilience scenarios from normal web flows.",
  "type": "module",
  "private": true,
  "bin": {
    "ux-gremlin": "./scripts/ux-gremlin.mjs"
  },
  "scripts": {
    "test": "node --test test/**/*.test.mjs",
    "validate": "node scripts/ux-gremlin-core.mjs check --plan examples/valid-plan.yaml",
    "summary": "node scripts/ux-gremlin-core.mjs summary --plan examples/valid-plan.yaml"
  },
  "engines": {
    "node": ">=20"
  }
}
