{
  "agents": "agents",
  "skills": "skills",
  "entrypointAgent": "web-ux-gremlin",
  "privateAgents": [],
  "mcpServers": "./.mcp.json",
  "hooks": "./hooks.json",
  "requirements": {
    "runtime": [
      {
        "name": "node",
        "reason": "Required to run npm, npx, and Playwright-based UX gremlin workflows."
      }
    ],
    "install": [
      {
        "name": "playwright",
        "command": "npm init playwright@latest"
      },
      {
        "name": "playwright-agents",
        "command": "npx playwright init-agents --loop=vscode",
        "after": "playwright"
      }
    ]
  },
  "name": "web-ux-gremlin",
  "metadata": {
    "version": "1.6.1",
    "description": "Create validated UX resilience plans and execute CLI/MCP gremlin runs."
  }
}
