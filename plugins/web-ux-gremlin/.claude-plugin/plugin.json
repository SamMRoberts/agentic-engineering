{
  "name": "web-ux-gremlin",
  "version": "1.6.0",
  "description": "Create validated UX resilience plans and execute CLI/MCP gremlin runs.",
  "author": {
    "name": "Sam Roberts",
    "url": "https://github.com/SamMRoberts"
  },
  "homepage": "https://github.com/SamMRoberts/agentic-engineering/tree/main/plugins/web-ux-gremlin",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamMRoberts/agentic-engineering"
  },
  "license": "MIT",
  "keywords": [],
  "agents": "./agents/",
  "skills": "./skills/",
  "hooks": "./hooks.json",
  "mcpServers": "./.mcp.json",
  "privateAgents": [
    "playwright-test-planner",
    "playwright-test-generator",
    "playwright-test-healer"
  ],
  "requirements": {
    "runtime": [
      {
        "name": "node",
        "reason": "Required to run npm, npx, and Playwright-based UX gremlin workflows."
      }
    ],
    "install": [
      {
        "name": "playwright",
        "command": "npm init playwright@latest"
      },
      {
        "name": "playwright-agents",
        "command": "npx playwright init-agents --loop=vscode",
        "after": "playwright"
      }
    ]
  }
}