{
  "name": "sammroberts-marketplace",
  "interface": {
    "displayName": "SamMRoberts Marketplace"
  },
  "plugins": [
    {
      "name": "agent-compat",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/SamMRoberts/agentic-engineering.git",
        "path": "plugins/agent-compat",
        "ref": "develop"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "description": "Generate compact Codex and Claude routing stubs with per-agent references from Copilot *.agent.md custom agents."
    }
  ]
}