{
  "name": "sammroberts-marketplace",
  "interface": {
    "displayName": "SamMRoberts Marketplace"
  },
  "plugins": [
    {
      "name": "agent-compat",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/SamMRoberts/agentic-engineering.git",
        "path": "plugins/agent-compat",
        "ref": "main"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "description": "Generate Codex and Claude instruction overlays from Copilot *.agent.md custom agents."
    },
    {
      "name": "web-ux-test",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/SamMRoberts/agentic-engineering.git",
        "path": "plugins/web-ux-test",
        "ref": "main"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Testing",
      "description": "Workflow-enforced Playwright UX testing: schema-validated plans, gated execution, deterministic repair loop."
    }
  ]
}
