{
  "SessionStart": [
    {
      "name": "change-control-init",
      "command": "node skills/change-control-compiler/scripts/change-control.mjs init",
      "timeoutSeconds": 10
    }
  ],
  "PostToolUse": [
    {
      "name": "change-control-drift",
      "command": "node skills/change-control-compiler/scripts/change-control.mjs drift",
      "timeoutSeconds": 10
    }
  ],
  "Stop": [
    {
      "name": "change-control-check",
      "command": "node skills/change-control-compiler/scripts/change-control.mjs check",
      "timeoutSeconds": 10
    },
    {
      "name": "change-control-final-drift",
      "command": "node skills/change-control-compiler/scripts/change-control.mjs drift",
      "timeoutSeconds": 10
    }
  ]
}
