{
  "description": "Example Codex-style hook wiring for Agent On-Ramp Coach. Event names and schemas vary by host version; adapt before use. Hooks support enforcement but do not force skill selection.",
  "hooks": {
    "SessionStart": [
      {
        "name": "initialize-on-ramp-session",
        "command": "node skills/agent-on-ramp-coach/scripts/onramp.mjs init",
        "timeoutSeconds": 10
      },
      {
        "name": "snapshot-git-state",
        "command": "node skills/agent-on-ramp-coach/scripts/onramp.mjs snapshot",
        "timeoutSeconds": 10
      }
    ],
    "BeforeFinalResponse": [
      {
        "name": "check-on-ramp-session",
        "command": "node skills/agent-on-ramp-coach/scripts/onramp.mjs check",
        "timeoutSeconds": 10
      },
      {
        "name": "enforce-no-edits-for-read-only-levels",
        "command": "node skills/agent-on-ramp-coach/scripts/onramp.mjs no-edits",
        "timeoutSeconds": 10
      }
    ]
  }
}
