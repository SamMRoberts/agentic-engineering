{
  "name": "web-ux-testing-agent-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright CLI runner for web-ux-testing-agent: validates plans, generates specs, executes them, and writes reports.",
  "bin": {
    "web-ux-runner": "src/cli.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "test:e2e": "playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
