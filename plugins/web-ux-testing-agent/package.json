{
  "name": "web-ux-testing-agent",
  "version": "0.1.0",
  "description": "Cross-agent plugin (Codex, Claude, Copilot) for defining, running, debugging, and reporting Playwright-based web UX validation plans.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test test/**/*.test.mjs",
    "validate:plan": "node skills/plan-authoring/scripts/validate-plan.mjs",
    "normalize:plan": "node skills/plan-authoring/scripts/normalize-plan.mjs",
    "generate:test": "node skills/playwright-generation/scripts/generate-playwright-test.mjs",
    "report": "node skills/report-generation/scripts/generate-report.mjs",
    "build:runner": "npm --prefix runner run build",
    "build:mcp": "npm --prefix mcp run build",
    "build:ui": "npm --prefix ui run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.1"
  }
}
