{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/SamMRoberts/agentic-engineering/plugins/web-ux-testing-agent/schemas/test-report.schema.json",
  "title": "Web UX Test Report",
  "description": "Normalized result of executing a web UX test plan through the Playwright CLI. Produced by the runner and consumed by the reporter, MCP report-viewer, and UI.",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "status", "started_at", "finished_at", "steps"],
  "properties": {
    "schema_version": { "type": "string", "default": "1.0" },
    "plan_id": { "type": "string", "description": "id of the executed plan." },
    "plan_title": { "type": "string" },
    "run_id": { "type": "string", "description": "Unique id for this run, typically a timestamp." },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "timedout", "skipped", "interrupted"],
      "description": "Overall outcome of the run."
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "description": "Snapshot of the environment block used for the run (base_url, stage, browser)."
    },
    "steps": {
      "type": "array",
      "description": "Per-step results in execution order.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "timedout", "skipped"]
          },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "error": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "message": { "type": "string" },
              "stack": { "type": "string" },
              "snippet": { "type": "string" }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Paths to captured evidence, relative to the report directory.",
      "properties": {
        "trace": { "type": "string" },
        "video": { "type": "string" },
        "screenshots": { "type": "array", "items": { "type": "string" } },
        "playwright_json": { "type": "string" },
        "html_report": { "type": "string" },
        "console_log": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "flaky": { "type": "integer", "minimum": 0 }
      }
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional failure classification added by the debugger subagent.",
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "product_bug",
            "selector_drift",
            "timing_issue",
            "missing_auth",
            "changed_workflow",
            "environment_issue",
            "invalid_test_plan",
            "unknown"
          ]
        },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "rationale": { "type": "string" },
        "recommended_repairs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
