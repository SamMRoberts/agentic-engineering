{
  "name": "web-ux-testing-agent-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for web-ux-testing-agent: list/get/save/validate plans, run plans via the Playwright CLI runner, and view reports. Ships plan-editor and report-viewer MCP Apps.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "serve": "tsx main.ts",
    "serve:stdio": "tsx main.ts --stdio",
    "dev": "tsx --watch main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
