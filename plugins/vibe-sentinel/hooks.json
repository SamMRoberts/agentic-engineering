{
    "hooks": {
        "SessionStart": [
            {
                "name": "vibe-sentinel-assumption-init",
                "command": "vibe-sentinel assumption-gate init",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-init",
                "command": "vibe-sentinel change-control init",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-scope-guard-init",
                "command": "vibe-sentinel scope-guard init",
                "timeoutSeconds": 10
            }
        ],
        "PostToolUse": [
            {
                "name": "vibe-sentinel-change-control-drift",
                "command": "vibe-sentinel change-control drift",
                "timeoutSeconds": 10
            }
        ],
        "Stop": [
            {
                "name": "vibe-sentinel-assumption-check",
                "command": "vibe-sentinel assumption-gate check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-check",
                "command": "vibe-sentinel change-control check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-scope-guard-check",
                "command": "vibe-sentinel scope-guard check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-final-drift",
                "command": "vibe-sentinel change-control drift",
                "timeoutSeconds": 10
            }
        ]
    }
}