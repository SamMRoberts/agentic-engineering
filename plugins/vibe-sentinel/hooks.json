{
    "hooks": {
        "SessionStart": [
            {
                "name": "vibe-sentinel-assumption-init",
                "command": "node plugins/vibe-sentinel/scripts/assumption-gate.mjs init",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-init",
                "command": "node plugins/vibe-sentinel/scripts/change-control.mjs init",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-scope-guard-init",
                "command": "node plugins/vibe-sentinel/scripts/scope-guard.mjs init",
                "timeoutSeconds": 10
            }
        ],
        "PostToolUse": [
            {
                "name": "vibe-sentinel-change-control-drift",
                "command": "node plugins/vibe-sentinel/scripts/change-control.mjs drift",
                "timeoutSeconds": 10
            }
        ],
        "Stop": [
            {
                "name": "vibe-sentinel-assumption-check",
                "command": "node plugins/vibe-sentinel/scripts/assumption-gate.mjs check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-check",
                "command": "node plugins/vibe-sentinel/scripts/change-control.mjs check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-scope-guard-check",
                "command": "node plugins/vibe-sentinel/scripts/scope-guard.mjs check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-final-drift",
                "command": "node plugins/vibe-sentinel/scripts/change-control.mjs drift",
                "timeoutSeconds": 10
            }
        ]
    }
}