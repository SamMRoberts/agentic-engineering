{
    "hooks": [
        {
            "event": "SessionStart",
            "name": "vibe-sentinel-assumption-init",
            "command": "node scripts/assumption-gate.mjs init",
            "timeoutSeconds": 10
        },
        {
            "event": "SessionStart",
            "name": "vibe-sentinel-change-control-init",
            "command": "node scripts/change-control.mjs init",
            "timeoutSeconds": 10
        },
        {
            "event": "SessionStart",
            "name": "vibe-sentinel-scope-guard-init",
            "command": "node scripts/scope-guard.mjs init",
            "timeoutSeconds": 10
        },
        {
            "event": "PostToolUse",
            "name": "vibe-sentinel-change-control-drift",
            "command": "node scripts/change-control.mjs drift",
            "timeoutSeconds": 10
        },
        {
            "event": "Stop",
            "name": "vibe-sentinel-assumption-check",
            "command": "node scripts/assumption-gate.mjs check",
            "timeoutSeconds": 10
        },
        {
            "event": "Stop",
            "name": "vibe-sentinel-change-control-check",
            "command": "node scripts/change-control.mjs check",
            "timeoutSeconds": 10
        },
        {
            "event": "Stop",
            "name": "vibe-sentinel-scope-guard-check",
            "command": "node scripts/scope-guard.mjs check",
            "timeoutSeconds": 10
        },
        {
            "event": "Stop",
            "name": "vibe-sentinel-change-control-final-drift",
            "command": "node scripts/change-control.mjs drift",
            "timeoutSeconds": 10
        }
    ]
}