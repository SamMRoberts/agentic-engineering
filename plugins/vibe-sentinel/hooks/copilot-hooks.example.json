{
    "hooks": {
        "sessionStart": [
            {
                "name": "vibe-sentinel-assumption-init",
                "command": "node plugins/vibe-sentinel/bin/assumption-gate.mjs init",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-init",
                "command": "node plugins/vibe-sentinel/bin/change-control.mjs init",
                "timeoutSeconds": 10
            }
        ],
        "postToolUse": [
            {
                "name": "vibe-sentinel-change-control-drift",
                "command": "node plugins/vibe-sentinel/bin/change-control.mjs drift",
                "timeoutSeconds": 10
            }
        ],
        "sessionEnd": [
            {
                "name": "vibe-sentinel-assumption-check",
                "command": "node plugins/vibe-sentinel/bin/assumption-gate.mjs check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-check",
                "command": "node plugins/vibe-sentinel/bin/change-control.mjs check",
                "timeoutSeconds": 10
            },
            {
                "name": "vibe-sentinel-change-control-final-drift",
                "command": "node plugins/vibe-sentinel/bin/change-control.mjs drift",
                "timeoutSeconds": 10
            }
        ]
    }
}