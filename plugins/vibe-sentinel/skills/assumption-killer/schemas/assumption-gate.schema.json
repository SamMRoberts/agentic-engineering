{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/assumption-killer/assumption-gate.schema.json",
  "title": "Assumption Gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task", "assumptions", "final_verification"],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "goal", "scope", "non_goals"],
      "properties": {
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "scope": { "type": "string" },
        "non_goals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "statement",
          "category",
          "risk_level",
          "verification_method",
          "evidence",
          "status",
          "files_checked",
          "commands_run",
          "impact_if_wrong",
          "decision"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "category": {
            "enum": [
              "repo_structure",
              "existing_behavior",
              "test_behavior",
              "runtime_behavior",
              "tooling_behavior",
              "parser_behavior",
              "ux_behavior",
              "data_model",
              "api_contract",
              "security_or_permissions",
              "backwards_compatibility",
              "deployment_or_ci"
            ]
          },
          "risk_level": {
            "enum": ["low", "medium", "high", "critical"]
          },
          "verification_method": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "enum": ["verified", "disproven", "unknown"]
          },
          "files_checked": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands_run": {
            "type": "array",
            "items": { "type": "string" }
          },
          "impact_if_wrong": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    },
    "final_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands_run", "tests_run", "result", "notes"],
      "properties": {
        "commands_run": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_run": {
          "type": "array",
          "items": { "type": "string" }
        },
        "result": {
          "enum": ["passed", "failed", "not_run"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
